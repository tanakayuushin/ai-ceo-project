# Claude API（すでにお持ちのキー）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# HeyGen API（Creator プラン $29/月 で取得）
# https://app.heygen.com/settings → API
HEYGEN_API_KEY=xxxxx
HEYGEN_AVATAR_ID=xxxxx   # ダッシュボードのアバター一覧で確認
HEYGEN_VOICE_ID=xxxxx    # 日本語音声のID（例: ja-JP-NanamiNeural）

# Kling AI API
# https://platform.klingai.com → API Keys
KLING_API_KEY=xxxxx
KLING_API_SECRET=xxxxx

# LINE Notify（完了通知用・無料）
# https://notify-bot.line.me/my/ でトークンを発行
LINE_NOTIFY_TOKEN=xxxxx
